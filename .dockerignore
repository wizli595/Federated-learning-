# Python environments - never copy venvs into the image
**/.venv/
**/venv/
**/__pycache__/
**/*.pyc
**/*.pyo

# Runtime data - mounted as volumes at runtime
fl/data/
fl/output/

# Frontend build artifacts — source files needed for dashboard image build
dashboard/node_modules/
dashboard/dist/

# Git
.git/
.gitignore

# Misc
*.md
error.txt
