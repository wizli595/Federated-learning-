# ─── FL Server (also serves as REST API) ──────────────────────
FL_SERVER_HOST=0.0.0.0
FL_SERVER_PORT=8080
FL_ROUNDS=10
FL_MIN_CLIENTS=2

# ─── Clients ──────────────────────────────────────────────────
CLIENT_SERVER_URL=http://fl-server:8080
CLIENT_ID=client-1
CLIENT_DATA_PATH=/data/dataset.csv

# ─── Dashboard ────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8080

# ─── Auth ─────────────────────────────────────────────────────
ACCESS_CODE=your-secret-code-here
JWT_SECRET=change-this-secret-in-production
